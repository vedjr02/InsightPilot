# Copy to backend/.env and fill in (never commit .env)
DATABASE_URL=
DATABASE_READONLY_URL=
GEMINI_API_KEY=
# Optional — defaults to gemini-flash-lite-latest (free-tier friendly)
GEMINI_MODEL=gemini-flash-lite-latest
# Comma-separated fallbacks when the primary model returns 503 / high demand
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest,gemini-2.5-flash
